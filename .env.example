# Postgres (docker-compose maps container 5432 -> host 5435 to avoid clashing with local PGs)
DATABASE_URL="postgresql://sellme:sellme@localhost:5435/sellme?schema=public"

# Redis (docker-compose maps 6379 -> 6381). Leave blank to use an in-memory cache fallback.
REDIS_URL="redis://localhost:6381"

# API
API_PORT=4000
API_CORS_ORIGIN="http://localhost:3100"

# Web -> API base URL (browser + server)
NEXT_PUBLIC_API_URL="http://localhost:4000"
