# Copy to deploy/.env.prod and fill in. NEVER commit the real file.
#   cp deploy/.env.prod.example deploy/.env.prod && nano deploy/.env.prod

# --- Postgres (runs as a container; these are the credentials it's created with) ---
POSTGRES_USER=justmac
POSTGRES_PASSWORD=change-me-strong-db-password
POSTGRES_DB=justmac

# --- API runtime ---
# Point at the postgres + redis services by their compose service names.
DATABASE_URL=postgresql://justmac:change-me-strong-db-password@postgres:5432/justmac?schema=public
REDIS_URL=redis://redis:6379
# Generate one: openssl rand -hex 32
JWT_SECRET=change-me-with-openssl-rand-hex-32
# The public origin the browser loads the site from (used for CORS).
# e.g. http://<EC2_PUBLIC_IP>:3100  or  https://justmac.yourdomain.com
API_CORS_ORIGIN=http://<EC2_PUBLIC_IP>:3100

# --- Web build (baked into the client bundle at build time) ---
# The public URL the browser uses to reach the API.
# e.g. http://<EC2_PUBLIC_IP>:4000  or  https://api.justmac.yourdomain.com
NEXT_PUBLIC_API_URL=http://<EC2_PUBLIC_IP>:4000
